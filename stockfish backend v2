from flask import Flask, request, jsonify
from flask_cors import CORS
import chess
import chess.engine

app = Flask(__name__)
CORS(app)

STOCKFISH_PATH = r"C:\Users\narne\Downloads\stockfish-windows-x86-64-avx2 (1)\stockfish\stockfish-windows-x86-64-avx2.exe"

engine = chess.engine.SimpleEngine.popen_uci(STOCKFISH_PATH)

@app.route("/best-move", methods=["POST"])
def best_move():
    data = request.json
    board = chess.Board(data["fen"])

    result = engine.play(board, chess.engine.Limit(depth=12))

    return jsonify({"move": result.move.uci()})

if __name__ == "__main__":
    app.run(port=5000)
